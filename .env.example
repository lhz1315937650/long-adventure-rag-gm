# Optional default server port
PORT=8787

# Real GM generation test
# Copy this file to .env only if you want a local template.
# Never commit real API keys.
GM_TEST_URL=http://localhost:8787
GM_MODE=openai-compatible
GM_BASE_URL=https://api.openai.com/v1
GM_MODEL=gpt-4.1-mini
GM_API_KEY=
GM_TEST_ACTION=选择谨慎观察周围人物与环境变化，等待 GM 裁定后续发展。
